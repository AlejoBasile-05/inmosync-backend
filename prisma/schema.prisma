
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum LeadStatus {
  HOT
  WARM
  COOL
  COLD
}

model Company {
  id String @id @default(uuid())
  name String
  metaPhoneNumber String?  @unique
  createdAt DateTime @default(now())
  agents Agent[]
  properties Property[]
}

model Agent {
  id String @id
  companyId String
  name String
  number String @unique
  email String @unique
  lastLeadReceivedAt DateTime @default(now())
  clients Client[]
  createdAt DateTime @default(now())
  company Company @relation(fields: [companyId], references:[id])
}

model Client {
  id Int @id @default(autoincrement())
  name String
  number String @unique
  score Float
  status LeadStatus @default(COLD)
  botActive Boolean    @default(true)
  messages Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  agentId String
  agent Agent @relation(fields: [agentId], references:[id])
}

model Message {
  id Int @id @default(autoincrement())
  text String
  origin String
  number String 
  clientId Int
  createdAt DateTime @default(now())
  client Client @relation(fields: [clientId], references: [id])
}

model Property {
  id Int @id @default(autoincrement())
  companyId String
  type String
  location String
  price Float
  currency String
  characteristics String[]
  reports Report[]
  company Company @relation(fields: [companyId], references:[id])
}

model Report {
  id Int @id @default(autoincrement())
  propertyId Int
  month String
  virtualViews Int
  leadsWhatsapp Int
  leadsCalificados Int
  physicalViews Int
  insightIA String
  property Property @relation(fields: [propertyId], references:[id])
}

